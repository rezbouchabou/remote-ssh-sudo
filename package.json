{
  "name": "remote-ssh-sudo",
  "displayName": "Sudo for Remote - SSH",
  "description": "Add, edit, save, delete, move, compress, extract, and change permissions/ownership of protected files with sudo/root privileges.",
  "version": "1.4.0",
  "publisher": "rezbouchabou",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "remote-ssh",
    "remote",
    "ssh",
    "root",
    "sudo",
    "move",
    "chmod",
    "chown",
    "compress",
    "extract",
    "permissions",
    "file-management"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rezbouchabou/remote-ssh-sudo"
  },
  "bugs": {
    "url": "https://github.com/rezbouchabou/remote-ssh-sudo/issues"
  },
  "homepage": "https://github.com/rezbouchabou/remote-ssh-sudo#readme",
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Sudo for Remote - SSH",
      "properties": {
        "remote-ssh-sudo.command": {
          "type": "string",
          "default": "sudo",
          "description": "The sudo command to execute. Default: 'sudo'. Use 'doas' for OpenBSD/Alpine."
        },
        "remote-ssh-sudo.timeoutSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 300,
          "description": "Timeout in seconds for sudo operations (10-300 seconds)."
        },
        "remote-ssh-sudo.extensionsToNotifyOnSave": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "List of extension IDs to notify when saving a file with sudo."
        }
      }
    },
    "commands": [
      {
        "command": "remote-ssh-sudo.saveFile",
        "title": "Save as Root",
        "category": "Sudo for Remote - SSH",
        "icon": "$(save)"
      },
      {
        "command": "remote-ssh-sudo.saveFileAsSpecifiedUser",
        "title": "Save as Specified User...",
        "category": "Sudo for Remote - SSH",
        "icon": "$(save-as)"
      },
      {
        "command": "remote-ssh-sudo.newFile",
        "title": "New File as Root...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.newFileAsSpecifiedUser",
        "title": "New File as Specified User...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.newFolder",
        "title": "New Folder as Root...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.newFolderAsSpecifiedUser",
        "title": "New Folder as Specified User...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.chmod",
        "title": "Change Permissions...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.chown",
        "title": "Change Owner/Group...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.compress",
        "title": "Compress to Archive...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.extract",
        "title": "Extract Archive...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.move",
        "title": "Move as Root...",
        "category": "Sudo for Remote - SSH"
      },
      {
        "command": "remote-ssh-sudo.delete",
        "title": "Delete as Root",
        "category": "Sudo for Remote - SSH"
      }
    ],
    "keybindings": [
      {
        "command": "remote-ssh-sudo.saveFile",
        "key": "ctrl+shift+alt+s",
        "mac": "cmd+shift+alt+s",
        "when": "resourceScheme == file"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "remote-ssh-sudo.saveFile",
          "group": "navigation@1",
          "when": "resourceScheme == file",
          "icon": "$(save)"
        },
        {
          "command": "remote-ssh-sudo.saveFileAsSpecifiedUser",
          "group": "navigation@2",
          "when": "resourceScheme == file",
          "icon": "$(save-as)"
        }
      ],
      "editor/title/context": [
        {
          "command": "remote-ssh-sudo.saveFile",
          "group": "1_modification@1",
          "when": "resourceScheme == file",
          "icon": "$(save)"
        },
        {
          "command": "remote-ssh-sudo.saveFileAsSpecifiedUser",
          "group": "1_modification@2",
          "when": "resourceScheme == file",
          "icon": "$(save-as)"
        }
      ],
      "explorer/context": [
        {
          "command": "remote-ssh-sudo.newFile",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@1"
        },
        {
          "command": "remote-ssh-sudo.newFolder",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@2"
        },
        {
          "command": "remote-ssh-sudo.newFileAsSpecifiedUser",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@3"
        },
        {
          "command": "remote-ssh-sudo.newFolderAsSpecifiedUser",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@4"
        },
        {
          "command": "remote-ssh-sudo.chmod",
          "group": "7_modification@5"
        },
        {
          "command": "remote-ssh-sudo.chown",
          "group": "7_modification@6"
        },
        {
          "command": "remote-ssh-sudo.compress",
          "group": "7_modification@7"
        },
        {
          "command": "remote-ssh-sudo.extract",
          "group": "7_modification@8"
        },
        {
          "command": "remote-ssh-sudo.move",
          "group": "7_modification@9"
        },
        {
          "command": "remote-ssh-sudo.delete",
          "group": "7_modification@10"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}